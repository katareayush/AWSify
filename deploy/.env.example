# --- Caddy ---
WEB_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com
LETSENCRYPT_EMAIL=you@yourdomain.com

# --- App URLs (must match the domains above) ---
APP_URL=https://app.yourdomain.com
API_URL=https://api.yourdomain.com
# Baked into the Next.js browser bundle at build time. Must equal API_URL + /v1.
NEXT_PUBLIC_API_URL=https://api.yourdomain.com/v1

# --- Runtime ---
NODE_ENV=production

# --- Postgres (Neon: use the POOLED url for runtime) ---
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/awsify?sslmode=require

# --- Redis (Upstash: use the rediss:// TLS url) ---
REDIS_URL=rediss://default:PASSWORD@xxx.upstash.io:6379

# --- Sessions / crypto ---
SESSION_SECRET=                 # 32+ random bytes, e.g. openssl rand -base64 48
ENV_ENCRYPTION_KEY=             # 32+ random bytes, e.g. openssl rand -base64 48
AWSIFY_EXTERNAL_ID_SALT=        # 16+ random bytes, e.g. openssl rand -base64 32
PULUMI_CONFIG_PASSPHRASE=       # any random string the worker uses for local stack state

# --- GitHub App ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_APP_ID=
GITHUB_APP_SLUG=aws-ify
GITHUB_APP_PRIVATE_KEY_BASE64=  # base64 of the *.private-key.pem contents
GITHUB_WEBHOOK_SECRET=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- AWS (awsify's own account that customers' roles trust) ---
AWSIFY_AWS_ACCOUNT_ID=          # 12-digit account ID
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=              # optional if EC2 has an instance role; required otherwise
AWS_SECRET_ACCESS_KEY=          # optional if EC2 has an instance role; required otherwise
