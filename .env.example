
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# Local services
# If you use Docker Compose from this repo, this default works.
DATABASE_URL=postgresql://awsify:awsify@localhost:5432/awsify
REDIS_URL=redis://localhost:6379

# Generate a long random value before using real sessions.
SESSION_SECRET=

# Generate a separate long random value for encrypting customer project env vars.
ENV_ENCRYPTION_KEY=

# GitHub OAuth app: used for user sign-in.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App: used for repository installation access.
GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=

# AI provider. Required for repo-analysis recommendations.
ANTHROPIC_API_KEY=

# AWSify's own AWS account ID. Required before generating customer CloudFormation trust policies.
AWSIFY_AWS_ACCOUNT_ID=

# Default AWS region for deployments. Set this explicitly.
AWS_REGION=

# Used to derive/check external IDs for customer role assumption.
AWSIFY_EXTERNAL_ID_SALT=

# Required by Pulumi local state encryption.
PULUMI_CONFIG_PASSPHRASE=
