{
  "name": "awsify",
  "private": true,
  "version": "0.1.0",
  "description": "AI-assisted, template-executed AWS deployments from GitHub to ECS Fargate.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "db:generate": "pnpm --filter @awsify/database prisma:generate",
    "db:migrate": "pnpm --filter @awsify/database prisma:migrate",
    "db:studio": "pnpm --filter @awsify/database prisma:studio",
    "worker": "pnpm --filter @awsify/worker dev",
    "api": "pnpm --filter @awsify/api dev",
    "web": "pnpm --filter @awsify/web dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
